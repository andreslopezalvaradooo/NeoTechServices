generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime
  user                  user      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model user {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime
  account       account[]
  session       session[]
  repairs       Repair[]
  consultings   Consulting[]
  developments  Development[]
}

model verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime

  @@index([identifier])
}

model Repair {
  id           String       @id @default(cuid())
  ticketNumber Int          @unique @default(autoincrement())
  name         String
  phone        String
  email        String
  type         String
  brand        String
  model        String
  issue        String
  problem      String
  status       RepairStatus @default(pending)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  userId       String?
  user         user?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  events       RepairEvent[]
}

enum RepairStatus {
  pending
  in_progress
  waiting_parts
  completed
}

model RepairEvent {
  id        String      @id @default(cuid())
  type      ActivityType
  repairId  String
  repair    Repair      @relation(fields: [repairId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@index([repairId])
}

model Consulting{
  id           String       @id @default(cuid())
  ticketNumber Int          @unique @default(autoincrement())
  name         String
  company      String?
  phone        String
  email        String
  service      String
  size         String
  challenge    String
  status       ConsultingStatus @default(pending)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  userId       String?
  user         user?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  events       ConsultingEvent[]
}

enum ConsultingStatus {
  pending
  in_progress
  completed
}

model ConsultingEvent {
  id        String      @id @default(cuid())
  type      ActivityType
  consultingId  String
  consulting    Consulting      @relation(fields: [consultingId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@index([consultingId])
}

enum ActivityType {
  assigned
  completed
  waiting
  approval
  created
}

model Development{
  id           String       @id @default(cuid())
  ticketNumber Int          @unique @default(autoincrement())
  name         String
  phone        String
  email        String
  type      String
  budget         String
  timeline    String
  description    String
  status       DevelopmentStatus @default(pending)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  userId       String?
  user         user?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  events       DevelopmentEvent[]
}

enum DevelopmentStatus {
  pending
  in_progress
  completed
}

model DevelopmentEvent {
  id        String      @id @default(cuid())
  type      ActivityType
  developmentId  String
  development    Development      @relation(fields: [developmentId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@index([developmentId])
}